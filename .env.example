# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Laravel API ──────────────────────────────────────────────────────────────
LARAVEL_API_URL=http://localhost:8000/api

# ─── JWT (must match Laravel's JWT_SECRET exactly) ────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── Internal Service Auth ────────────────────────────────────────────────────
# Used for Node → Laravel calls (X-Service-Secret header).
# Must match NODE_SERVICE_SECRET in Laravel .env.
INTERNAL_SERVICE_SECRET=your-inter-service-secret-here

# Long-lived admin JWT for legacy internal calls (optional).
# Generate: php artisan tinker
#   echo JWTAuth::fromUser(User::where('role','admin')->first());
INTERNAL_SERVICE_TOKEN=

# ─── Email / SMTP (primary) ───────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME="Task Management"

# ─── Resend (fallback when SMTP times out) ────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ─── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Redis (optional — falls back to in-memory cache if not set) ─────────────
REDIS_URL=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Analytics Cache ──────────────────────────────────────────────────────────
ANALYTICS_CACHE_TTL=3600           # seconds (default: 1 hour)

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
