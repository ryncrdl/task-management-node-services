PORT=3000
NODE_ENV=development

# Laravel API base URL
LARAVEL_API_URL=http://localhost:8000/api

# Shared JWT secret — must match Laravel's JWT_SECRET
JWT_SECRET=your-jwt-secret-key-here

# Long-lived JWT for internal service-to-service calls (cron jobs).
# Generate via: php artisan tinker
#   echo JWTAuth::fromUser(User::where('role','admin')->first());
# NEVER commit a real value here — update the actual .env on your server.
INTERNAL_SERVICE_TOKEN=

# Internal service-to-service auth secret (used when Node calls Laravel internal endpoints)
INTERNAL_SERVICE_SECRET=your-inter-service-secret-key

# Email / Nodemailer
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your-mailtrap-user
MAIL_PASS=your-mailtrap-password
MAIL_FROM=noreply@taskmanagement.com
MAIL_FROM_NAME="Task Management"

# Redis (optional — for cache; falls back to in-memory if not set)
REDIS_URL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Analytics cache TTL in seconds (default: 1 hour)
ANALYTICS_CACHE_TTL=3600

# Logging
LOG_LEVEL=info
